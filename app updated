function toZAR(n){ return “R”+Number(n).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,”,”); }
function getToday(){ return new Date().toISOString().split(“T”)[0]; }
function getTomorrow(){ const d=new Date(); d.setDate(d.getDate()+1); return d.toISOString().split(“T”)[0]; }

function canOrderForDate(dateStr){
const now=new Date(), todayStr=getToday();
const nowMins=now.getHours()*60+now.getMinutes();
const closeMins=ORDER_CLOSE_HOUR*60+ORDER_CLOSE_MIN;
const openMins=ORDER_OPEN_HOUR*60+ORDER_OPEN_MIN;
if(dateStr===todayStr){
if(nowMins>=closeMins) return {ok:false,reason:“Orders for today closed at 07:30. Place your order after 17:00 for tomorrow.”};
return {ok:true};
}
const tomorrow=new Date(); tomorrow.setDate(tomorrow.getDate()+1);
if(dateStr===tomorrow.toISOString().split(“T”)[0]){
if(nowMins<openMins&&nowMins>=closeMins) return {ok:false,reason:“Orders for tomorrow open at 17:00 today.”};
return {ok:true};
}
return {ok:true};
}

